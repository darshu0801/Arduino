#define RXD2 16
#define TXD2 17

void setup() {

  Serial.begin(115200);

  Serial2.begin(115200, SERIAL_8N1, RXD2, TXD2);

  Serial.println("UART Started");
}

void loop() {

  while (Serial2.available()) {

    uint8_t b = Serial2.read();

    Serial.print("0x");

    if (b < 16)
      Serial.print("0");

    Serial.print(b, HEX);

    Serial.print("  ");

    if (b >= 32 && b <= 126)
      Serial.write(b);

    Serial.println();
  }
}





#include <HardwareSerial.h>

HardwareSerial PMU(2);

void setup() {
  Serial.begin(115200);
  PMU.begin(115200, SERIAL_8N1, 16, 17);

  Serial.println("Loopback Test");
}

void loop() {
  static uint32_t t = 0;

  if (millis() - t > 1000) {
    t = millis();
    PMU.write(0x02);
    PMU.print("cmd(j)");
    PMU.write(0x0A);
  }

  while (PMU.available()) {
    uint8_t b = PMU.read();
    Serial.printf("%02X ", b);
  }
}





#define PIN 16

volatile uint32_t last = 0;

void IRAM_ATTR edgeISR()
{
    uint32_t now = micros();

    Serial.printf("%lu,%d\n",
                  now - last,
                  digitalRead(PIN));

    last = now;
}

void setup()
{
    Serial.begin(2000000);

    pinMode(PIN, INPUT);

    last = micros();

    attachInterrupt(PIN, edgeISR, CHANGE);
}

