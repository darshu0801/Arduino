#define RXD2 16
#define TXD2 17

void setup() {

  Serial.begin(115200);

  Serial2.begin(115200, SERIAL_8N1, RXD2, TXD2);

  Serial.println("UART Started");
}

void loop() {

  while (Serial2.available()) {

    uint8_t b = Serial2.read();

    Serial.print("0x");

    if (b < 16)
      Serial.print("0");

    Serial.print(b, HEX);

    Serial.print("  ");

    if (b >= 32 && b <= 126)
      Serial.write(b);

    Serial.println();
  }
}